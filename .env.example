# the URL this addon is reachable at - used to build your Stremio install
# link and stream URLs, so it has to be correct for playback to work.
# quick testing with no domain yet: http://your-server-ip:4040
# real use behind a reverse proxy: https://your-domain.com
ADDON_BASE_URL=http://your-server-ip:4040

# protects the served video files. generate one with: openssl rand -hex 24
FILES_SECRET_TOKEN=

# optional - only used as the initial install token on first run.
# leave empty and a random one gets generated automatically.
INSTALL_SECRET_TOKEN=

TZ=Etc/UTC
